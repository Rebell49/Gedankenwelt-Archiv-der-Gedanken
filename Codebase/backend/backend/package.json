{
  "name": "gedankenwelt-backend",
  "version": "1.0.0",
  "description": "Backend API for Gedankenwelt - 3D philosophical thought platform",
  "private": true,
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "NODE_ENV=development nodemon src/server.js",
    "start": "NODE_ENV=production node src/server.js",
    "test": "jest --coverage",
    "test:integration": "jest --testPathPattern=integration",
    "database:migrate": "npx prisma migrate dev",
    "database:migrate:deploy": "npx prisma migrate deploy",
    "database:seed": "node prisma/seed.js",
    "database:studio": "npx prisma studio",
    "lint": "eslint src --fix",
    "validate:env": "node scripts/validate-env.js"
  },
  "dependencies": {
    "@prisma/client": "^5.8.0",
    "axios": "^1.6.5",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.1.2",
    "node-cache": "^5.1.2",
    "redis": "^4.6.12",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prisma": "^5.8.0",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
